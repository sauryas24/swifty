
# Copy this file and rename it to exactly '.env' to test locally.

# 1. LOCAL DATABASE CONFIGURATION
# This connects to your local Docker container, keeping the production database safe!
DATABASE_URL=postgresql://testuser:testpassword@localhost:5432/swifty_test

# 2. SECURITY & AUTHENTICATION
# Dummy key for testing purposes
SECRET_KEY=super_secret_beta_testing_key_123

# 3. EMAIL SERVICE (OTP & Notifications)
# Testers: Please use a dummy/test email account with an App Password here
SMTP_EMAIL=dummy_test_email@gmail.com
SMTP_PASSWORD=dummy_app_password

# 4. FILE STORAGE (Cloudinary)
# Testers: Provide your own free-tier Cloudinary credentials to test uploads
CLOUDINARY_URL=cloudinary://dummy_api_key:dummy_api_secret@dummy_cloud_name